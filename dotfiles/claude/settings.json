{
  "permissions": {
    "allow": [
      "Bash",
      "Edit(**/*)",
      "Read(**/*)",
      "Write",
      "Glob(*)",
      "Grep(*)",
      "WebSearch",
      "Skill"
    ],
    "defaultMode": "dontAsk"
  },
  "mcpServers": {
    "gemini": {
      "command": "npx",
      "args": ["-y", "gemini-nanobanana-mcp@latest"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "alwaysThinkingEnabled": true,
  "model": "sonnet"
}
